STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:ae72fb24a18ba248b318c03acfdd407e3b5a7163
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:ae72fb24a18ba248b318c03acfdd407e3b5a7163
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:ae72fb24a18ba248b318c03acfdd407e3b5a7163
