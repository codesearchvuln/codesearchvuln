SCAN_WORKSPACE_INIT_IMAGE=vulhunter-local/scan-workspace-init:9fa0c4ebe9f2b9cb8b2f1582eca9a1124a5fbbcb
STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:9fa0c4ebe9f2b9cb8b2f1582eca9a1124a5fbbcb
NEXUS_WEB_IMAGE=vulhunter-local/nexus-web:9fa0c4ebe9f2b9cb8b2f1582eca9a1124a5fbbcb
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:9fa0c4ebe9f2b9cb8b2f1582eca9a1124a5fbbcb
