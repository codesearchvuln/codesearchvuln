STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:c9a83b8c4e4fc472bb64190c60633ebf6a6051e0
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:c9a83b8c4e4fc472bb64190c60633ebf6a6051e0
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:c9a83b8c4e4fc472bb64190c60633ebf6a6051e0
