STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:09834e4e5b92d410724a0ec0a4a22bb011326732
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:09834e4e5b92d410724a0ec0a4a22bb011326732
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:09834e4e5b92d410724a0ec0a4a22bb011326732
