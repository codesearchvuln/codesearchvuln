STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:d27b3ed7130db24b4dfb8162afe24e13aca25fc6
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:d27b3ed7130db24b4dfb8162afe24e13aca25fc6
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:d27b3ed7130db24b4dfb8162afe24e13aca25fc6
