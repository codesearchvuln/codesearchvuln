# Copy this file to offline-images.env before using offline mode.
# Then run bash ./scripts/offline-up.sh.
# This release tree does not support rebuilding backend/frontend from source.
# The default backend runtime image in this release tree comes from the runtime-plain target.
RUNNER_PREFLIGHT_OFFLINE_MODE=true
BACKEND_IMAGE=vulhunter-local/backend:b7c0d5ecce859567b2eaf8eae5408ce90f8937fd
POSTGRES_IMAGE=vulhunter-local/postgres:b7c0d5ecce859567b2eaf8eae5408ce90f8937fd
REDIS_IMAGE=vulhunter-local/redis:b7c0d5ecce859567b2eaf8eae5408ce90f8937fd
ADMINER_IMAGE=vulhunter-local/adminer:b7c0d5ecce859567b2eaf8eae5408ce90f8937fd
SCAN_WORKSPACE_INIT_IMAGE=vulhunter-local/scan-workspace-init:b7c0d5ecce859567b2eaf8eae5408ce90f8937fd
STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:b7c0d5ecce859567b2eaf8eae5408ce90f8937fd
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:b7c0d5ecce859567b2eaf8eae5408ce90f8937fd
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:b7c0d5ecce859567b2eaf8eae5408ce90f8937fd
