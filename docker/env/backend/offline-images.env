STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:4e8e0ce69a74f99d3d898eeccdd90289ccd5cd02
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:4e8e0ce69a74f99d3d898eeccdd90289ccd5cd02
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:4e8e0ce69a74f99d3d898eeccdd90289ccd5cd02
