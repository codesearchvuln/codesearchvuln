STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:e04d14eed7eeec8898e4981bc6a8314a885f81f2
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:e04d14eed7eeec8898e4981bc6a8314a885f81f2
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:e04d14eed7eeec8898e4981bc6a8314a885f81f2
