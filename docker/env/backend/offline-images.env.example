SCANNER_PMD_IMAGE=vulhunter-local/pmd-runner:e3ded70cd8ba936aabc77c13664b669c625f4cd3
FLOW_PARSER_RUNNER_IMAGE=vulhunter-local/flow-parser-runner:e3ded70cd8ba936aabc77c13664b669c625f4cd3
