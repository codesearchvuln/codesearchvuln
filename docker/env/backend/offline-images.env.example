STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:b75ebd7be7c4b9c19115917c78f77658b099ad50
NEXUS_WEB_IMAGE=vulhunter-local/nexus-web:b75ebd7be7c4b9c19115917c78f77658b099ad50
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:b75ebd7be7c4b9c19115917c78f77658b099ad50
