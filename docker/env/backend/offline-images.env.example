STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:4ad089b87ac6fc5de6136a10964e10463b7e682d
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:4ad089b87ac6fc5de6136a10964e10463b7e682d
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:4ad089b87ac6fc5de6136a10964e10463b7e682d
