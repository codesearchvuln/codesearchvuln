STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:9bb7ca502c95cee4f57313a72f53b3ca11790baf
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:9bb7ca502c95cee4f57313a72f53b3ca11790baf
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:9bb7ca502c95cee4f57313a72f53b3ca11790baf
