# Copy this file to offline-images.env before using offline mode.
# Then run bash ./scripts/offline-up.sh.
# This release tree does not support rebuilding backend/frontend from source.
# The default backend runtime image in this release tree comes from the runtime-plain target.
RUNNER_PREFLIGHT_OFFLINE_MODE=true
BACKEND_IMAGE=vulhunter-local/backend:e3ded70cd8ba936aabc77c13664b669c625f4cd3
POSTGRES_IMAGE=vulhunter-local/postgres:e3ded70cd8ba936aabc77c13664b669c625f4cd3
REDIS_IMAGE=vulhunter-local/redis:e3ded70cd8ba936aabc77c13664b669c625f4cd3
ADMINER_IMAGE=vulhunter-local/adminer:e3ded70cd8ba936aabc77c13664b669c625f4cd3
SCAN_WORKSPACE_INIT_IMAGE=vulhunter-local/scan-workspace-init:e3ded70cd8ba936aabc77c13664b669c625f4cd3
STATIC_FRONTEND_IMAGE=vulhunter-local/static-frontend:e3ded70cd8ba936aabc77c13664b669c625f4cd3
SANDBOX_RUNNER_IMAGE=vulhunter-local/sandbox-runner:e3ded70cd8ba936aabc77c13664b669c625f4cd3
SCANNER_YASA_IMAGE=vulhunter-local/yasa-runner:e3ded70cd8ba936aabc77c13664b669c625f4cd3
SCANNER_OPENGREP_IMAGE=vulhunter-local/opengrep-runner:e3ded70cd8ba936aabc77c13664b669c625f4cd3
